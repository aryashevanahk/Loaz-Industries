# ============================================
# .htaccess - Loaz Industries (Minimal Version)
# ============================================

RewriteEngine On
DirectoryIndex homepage.php index.php

# Redirect root to homepage
RewriteRule ^$ homepage.php [L]

# Block sensitive directories
RewriteRule ^(config|includes)/ - [F,L]

# PHP files router
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?page=$1 [QSA,L]

# Error pages
ErrorDocument 404 /loaz_industries/404.php
ErrorDocument 403 /loaz_industries/403.php

# Security headers (jika mod_headers aktif)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# PHP settings
php_value upload_max_filesize 10M
php_value post_max_size 10M
php_value max_execution_time 300
php_value memory_limit 256M
php_value date.timezone Asia/Jakarta

# Prevent directory listing
Options -Indexes

# ============================================
# END OF .htaccess
# ============================================